# ═══════════════════════════════════════════════════════════════
# Job Finding Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── Federal Jobs ───────────────────────────────────────────────
# Get your API key at: https://developer.usajobs.gov/APIRequest/Index
USAJOBS_API_KEY=your_usajobs_api_key_here
USAJOBS_EMAIL=your_email@example.com

# ─── Corporate Aggregator (RapidAPI) ────────────────────────────
# Get your API key at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Global Job Aggregator ───────────────────────────────────────
# Get your App ID and Key at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ─── ZipRecruiter (Optional, v2.0) ───────────────────────────────
# Get your API key at: https://www.ziprecruiter.com/hiring/api
ZIPRECRUITER_API_KEY=your_ziprecruiter_api_key_here

# ─── ScraperAPI (Optional, for Indeed) ───────────────────────────
# Get your API key at: https://www.scraperapi.com/
SCRAPERAPI_KEY=your_scraperapi_key_here

# ─── Turso Cloud Database (Optional) ─────────────────────────────
# If not set, falls back to local SQLite at data/jobs.db
# Get your database at: https://turso.tech/
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ─── Notes ───────────────────────────────────────────────────────
# • Remotive, Arbeitnow, JoinRise, LinkedIn, Glassdoor, Monster,
#   RemoteOK, Careers, and Dice agents require NO API keys
# • The agent works with any subset of keys — unconfigured sources
#   are gracefully skipped
# • All keys are optional except where noted above
